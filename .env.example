# Firebase Client Configuration (from Firebase Console > Project Settings)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase Admin SDK (Download JSON from Project Settings > Service Accounts)
# Paste the entire JSON content as a single line string here
FIREBASE_SERVICE_ACCOUNT_JSON=

# Cloudinary Configuration (from Cloudinary Dashboard)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Gemini AI (Optional - for future AI features)
GEMINI_API_KEY=

# Mapbox
VITE_MAPBOX_ACCESS_TOKEN=

# App Settings
NODE_ENV=development
PORT=3000
APP_URL=
